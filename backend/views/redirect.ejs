<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- cursive font -->
    <link
        href="https://fonts.googleapis.com/css2?family=Cedarville+Cursive&display=swap"
        rel="stylesheet"
    />

    <title>Redirecting...</title>

    <script>
        setTimeout(() => {
            window.location.href = "<%= originalUrl %>";
        }, 5000);
    </script>

    <style>
        :root {
            --bg: #050505;
            --card: rgba(255,255,255,0.04);
            --border: rgba(255,255,255,0.08);
            --text: #ffffff;
            --muted: #9f9f9f;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px;
            overflow: hidden;

            background:
                radial-gradient(circle at top, rgba(255,255,255,0.06), transparent 40%),
                #050505;

            font-family: Inter, -apple-system, BlinkMacSystemFont, sans-serif;
            color: var(--text);
        }

        /* ambient glow */
        body::before {
            content: '';
            position: absolute;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(255,255,255,0.08), transparent 70%);
            filter: blur(60px);
            pointer-events: none;
        }

        .container {
            position: relative;
            overflow: hidden;

            width: 100%;
            max-width: 650px;

            padding: 60px 50px;

            border-radius: 32px;
            border: 1px solid var(--border);

            background: var(--card);
            backdrop-filter: blur(24px);

            box-shadow:
                0 0 60px rgba(255,255,255,0.04),
                inset 0 1px 0 rgba(255,255,255,0.04);

            text-align: center;
        }

        /* huge background text */
        .bg-text {
            position: absolute;
            inset: 0;

            display: flex;
            align-items: center;
            justify-content: center;

            font-size: 10rem;
            font-weight: 900;
            font-style: italic;

            color: rgba(255,255,255,0.03);

            pointer-events: none;
            user-select: none;
        }

        .brand {
            position: relative;
            z-index: 2;

            font-family: "Cedarville Cursive", cursive;
            font-size: 56px;
            color: white;

            margin-bottom: 10px;
        }

        .subtitle {
            position: relative;
            z-index: 2;

            font-size: 14px;
            letter-spacing: 0.3em;
            text-transform: uppercase;
            color: var(--muted);

            margin-bottom: 30px;
        }

        h1 {
            position: relative;
            z-index: 2;

            font-size: 42px;
            font-weight: 900;
            letter-spacing: -2px;

            background: linear-gradient(
                to right,
                #ffffff,
                #d4d4d4,
                #737373
            );

            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;

            margin-bottom: 14px;
        }

        .desc {
            position: relative;
            z-index: 2;

            font-size: 15px;
            line-height: 1.7;
            color: var(--muted);

            max-width: 500px;
            margin: 0 auto 35px;
        }

        .progress {
            position: relative;
            z-index: 2;

            width: 100%;
            height: 4px;

            overflow: hidden;

            border-radius: 999px;
            background: rgba(255,255,255,0.08);

            margin-bottom: 35px;
        }

        .progress-bar {
            width: 0%;
            height: 100%;

            border-radius: 999px;

            background: linear-gradient(
                to right,
                #ffffff,
                #a1a1aa
            );

            animation: load 5s linear forwards;
        }

        @keyframes load {
            to {
                width: 100%;
            }
        }

        .url-box {
            position: relative;
            z-index: 2;

            margin-bottom: 35px;

            padding: 18px;

            border-radius: 20px;
            border: 1px solid var(--border);

            background: rgba(0,0,0,0.35);

            color: white;

            font-size: 14px;
            line-height: 1.6;
            word-break: break-all;

            font-family: monospace;
        }

        .actions {
            position: relative;
            z-index: 2;

            display: flex;
            align-items: center;
            justify-content: center;
            gap: 16px;

            flex-wrap: wrap;
        }

        .btn-primary {
            display: inline-flex;
            align-items: center;
            justify-content: center;

            padding: 14px 28px;

            border-radius: 18px;

            background: white;
            color: black;

            font-size: 14px;
            font-weight: 700;

            text-decoration: none;

            transition: all 0.3s ease;
        }

        .btn-primary:hover {
            transform: translateY(-2px) scale(1.03);
            background: #e4e4e7;

            box-shadow: 0 0 25px rgba(255,255,255,0.15);
        }

        .btn-secondary {
            display: inline-flex;
            align-items: center;
            justify-content: center;

            padding: 14px 28px;

            border-radius: 18px;

            border: 1px solid var(--border);

            background: rgba(255,255,255,0.04);
            color: white;

            font-size: 14px;
            font-weight: 600;

            text-decoration: none;

            transition: all 0.3s ease;
        }

        .btn-secondary:hover {
            background: rgba(255,255,255,0.08);
            border-color: rgba(255,255,255,0.15);
        }

        @media (max-width: 768px) {
            body {
                padding: 20px;
            }

            .container {
                padding: 45px 24px;
            }

            .brand {
                font-size: 42px;
            }

            h1 {
                font-size: 34px;
            }

            .bg-text {
                font-size: 6rem;
            }
        }
    </style>
</head>

<body>

    <div class="container">

        <div class="bg-text">
            shawty
        </div>

        <div class="brand">
            shawty
        </div>

        <p class="subtitle">
            clean links • fast redirects
        </p>

        <div class="progress">
            <div class="progress-bar"></div>
        </div>

        <h1>
            Taking you there
        </h1>

        <p class="desc">
            You are being redirected to an external destination.
            Please verify the link below before continuing.
        </p>

        <div class="url-box">
            <%= originalUrl %>
        </div>

        <div class="actions">

            <a href="<%= originalUrl %>" class="btn-primary">
                Redirect Now
            </a>

            <a href="https://yourfrontend.com" class="btn-secondary">
                Visit Shawty
            </a>

        </div>

    </div>

</body>
</html>